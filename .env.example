# Copy to .env and fill in. .env is gitignored — never commit it.

# Base URL of your deployed OAT Overview worker, no trailing slash.
OAT_WORKER_URL=https://your-worker.your-subdomain.workers.dev

# Bearer token guarding the worker's /api/admin/* routes.
# Same value as the worker's ADMIN_TOKEN secret (`wrangler secret put ADMIN_TOKEN`).
OAT_ADMIN_TOKEN=replace-me

# Google Sheet holding the creator roster — the id from the sheet's URL:
#   https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
# The sheet may contain personal data. Keep it permission-gated; do not
# set it to "anyone with the link".
OAT_SHEET_ID=replace-me
